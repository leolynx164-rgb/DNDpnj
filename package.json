{
  "name": "forge-du-pnj",
  "version": "1.0.0",
  "description": "Forge du PNJ — Générateur de personnages Donjons & Dragons 5e, propulsé par l'IA",
  "main": "main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron --no-sandbox .",
    "dev": "electron --no-sandbox . --dev",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.forge.pnj",
    "productName": "Forge du PNJ",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "style.css",
      "app.js",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.role-playing-games",
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "keywords": [],
  "type": "commonjs"
}
